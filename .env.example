# Firebase Configuration
# Copy this file to .env and fill in your Firebase project values
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# App URL Configuration
# The URL where the main SeraVault app is hosted
VITE_APP_URL=https://seravault-8c764-app.web.app

# Landing Page URL - The URL where the landing page is hosted
VITE_LANDING_URL=https://seravault-8c764.web.app
